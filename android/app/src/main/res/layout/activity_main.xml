<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/app_name"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/paramsText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="OCT: 0  TR: 0  SCL: -  MOD: -"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnOctaveDown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OCT-" />
        <Button android:id="@+id/btnOctaveUp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OCT+" />
        <Button android:id="@+id/btnTransposeDown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TR-" />
        <Button android:id="@+id/btnTransposeUp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TR+" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnScaleDown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SCL-" />
        <Button android:id="@+id/btnScaleUp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SCL+" />
        <Button android:id="@+id/btnModeDown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MOD-" />
        <Button android:id="@+id/btnModeUp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MOD+" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">
        <Button android:id="@+id/btnLoadSoundfont" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Load Soundfont..." />
        <Button android:id="@+id/btnDefaultSoundfont" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Default Soundfont" />
    </LinearLayout>

    <TextView
        android:id="@+id/soundfontText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Soundfont: default"
        android:textSize="12sp" />

    <Button
        android:id="@+id/btnInstrument"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Instrument..." />

    <TextView
        android:id="@+id/instrumentText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Instrument: Acoustic Grand Piano"
        android:textSize="12sp" />

</LinearLayout>
